# --- Core ---
# Koyeb/Render set PORT automatically; local default 3001.
PORT=3001

# Managed Postgres (Supabase / Neon). Include ?sslmode=require for cloud.
# Local example (own Postgres / Timescale):
DATABASE_URL=postgresql://user:pass@localhost:5432/trading

# Managed Redis (Upstash redis:// or rediss://). Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# --- Observability / operational alerting (all optional) ---
SENTRY_DSN=
ALERT_WEBHOOK_URL=
RESEND_API_KEY=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_EMAIL_MIN_SEVERITY=warning

# --- Auth ---
JWT_SECRET=
JWT_REFRESH_SECRET=
GOOGLE_CLIENT_ID=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_BASIC=
STRIPE_PRICE_ID_PREMIUM=

# --- Market data ---
MARKET_DATA_PROVIDER=alpaca
ALPACA_DATA_FEED=iex
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=

# --- Model lifecycle ---
MODEL_ROLLBACK_HIT_RATE=0.45
MODEL_ROLLBACK_MIN_SAMPLES=20
MODEL_MIN_SOAK_HOURS=72
MODEL_MIN_SHADOW_SAMPLES=20
MODEL_SHADOW_MAX_CANDIDATES=2

# --- Sibling services (Koyeb/Render public URLs in production) ---
ML_SERVICE_URL=http://localhost:8001
BACKTEST_SERVICE_URL=http://localhost:8002

# --- Broker ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALLOW_LIVE_BROKER=false
ALLOW_FULL_AUTO_LIVE=false
MAX_TOTAL_EXPOSURE_PCT=50
KILL_SWITCH_FLATTEN=false

# --- Encryption (32 bytes hex): openssl rand -hex 32 ---
ENCRYPTION_KEY=

# --- Frontend origin for CORS (Vercel URL in production) ---
WEB_ORIGIN=http://localhost:3000
