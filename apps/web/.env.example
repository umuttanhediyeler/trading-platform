# Copy to `.env.local` for local Next.js (`cp .env.example .env.local`).
# On Vercel, set these in Project → Settings → Environment Variables.

# Public absolute URL of the Nest API (Koyeb/Render in production).
# Local: http://localhost:3001
# Prod:  https://your-api-xxxxx.koyeb.app
NEXT_PUBLIC_API_URL=http://localhost:3001

# Socket.IO origin (usually same as NEXT_PUBLIC_API_URL).
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Optional SSR-only override if the server must reach the API via a different URL.
# INTERNAL_API_URL=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sentry (optional)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
