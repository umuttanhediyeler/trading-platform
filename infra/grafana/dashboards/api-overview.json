{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "Apex Scan — API Overview",
  "uid": "apex-api-overview",
  "tags": ["apex-scan", "api"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "API up",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "targets": [ { "refId": "A", "expr": "up{job=\"trading-api\"}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Open signals",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "api_signals_open", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active models",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "api_models_active", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Open broker orders",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "api_broker_orders_open", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Process CPU (cores)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "targets": [ { "refId": "A", "expr": "rate(api_process_cpu_seconds_total[5m])", "legendFormat": "cpu cores", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Resident memory",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [ { "refId": "A", "expr": "api_process_resident_memory_bytes", "legendFormat": "rss", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Event loop lag (p99)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [ { "refId": "A", "expr": "api_nodejs_eventloop_lag_p99_seconds", "legendFormat": "p99 lag", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Node heap used",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [ { "refId": "A", "expr": "api_nodejs_heap_size_used_bytes", "legendFormat": "heap used", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    }
  ]
}
