{
  "name": "trading-platform",
  "description": "NestJS API from GHCR image",
  "billing": {
    "deploymentPlan": "nf-compute-10"
  },
  "deployment": {
    "instances": 1,
    "external": {
      "imagePath": "ghcr.io/umuttanhediyeler/trading-platform-api:latest"
    },
    "docker": {
      "configType": "default"
    },
    "storage": {
      "ephemeralStorage": { "storageSize": 1024 }
    }
  },
  "ports": [
    {
      "name": "p01",
      "internalPort": 3001,
      "public": true,
      "protocol": "HTTP"
    }
  ],
  "healthChecks": [
    {
      "protocol": "HTTP",
      "type": "readinessProbe",
      "path": "/health",
      "port": 3001,
      "initialDelaySeconds": 45,
      "periodSeconds": 30,
      "timeoutSeconds": 10,
      "failureThreshold": 5,
      "successThreshold": 1
    }
  ]
}
