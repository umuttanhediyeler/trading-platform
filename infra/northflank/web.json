{
  "name": "web",
  "description": "Next.js frontend",
  "billing": {
    "deploymentPlan": "nf-compute-20",
    "buildPlan": "nf-compute-400-16"
  },
  "deployment": {
    "instances": 1,
    "docker": {
      "configType": "default"
    }
  },
  "ports": [
    {
      "name": "p01",
      "internalPort": 3000,
      "public": true,
      "protocol": "HTTP"
    }
  ],
  "buildSource": "git",
  "vcsData": {
    "projectUrl": "https://github.com/umuttanhediyeler/trading-platform",
    "projectType": "github",
    "projectBranch": "main"
  },
  "buildSettings": {
    "dockerfile": {
      "buildEngine": "buildkit",
      "dockerFilePath": "/apps/web/Dockerfile",
      "dockerWorkDir": "/",
      "buildkit": {
        "useCache": true,
        "cacheStorageSize": 32768
      }
    }
  },
  "buildConfiguration": {
    "pathIgnoreRules": [
      "apps/api/**",
      "packages/ml/**",
      "packages/backtest/**",
      "infra/**",
      ".github/**"
    ]
  },
  "healthChecks": [
    {
      "protocol": "HTTP",
      "type": "readinessProbe",
      "path": "/",
      "port": 3000,
      "initialDelaySeconds": 30,
      "periodSeconds": 30,
      "timeoutSeconds": 10,
      "failureThreshold": 5,
      "successThreshold": 1
    }
  ]
}