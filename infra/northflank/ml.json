{
  "name": "ml",
  "description": "Python ML inference service",
  "billing": {
    "deploymentPlan": "nf-compute-50",
    "buildPlan": "nf-compute-200-8"
  },
  "deployment": {
    "instances": 1,
    "docker": { "configType": "default" }
  },
  "ports": [
    {
      "name": "p01",
      "internalPort": 8001,
      "public": false,
      "protocol": "HTTP"
    }
  ],
  "buildSource": "git",
  "vcsData": {
    "projectUrl": "https://github.com/umuttanhediyeler/trading-platform",
    "projectType": "github",
    "projectBranch": "main"
  },
  "buildSettings": {
    "dockerfile": {
      "buildEngine": "buildkit",
      "dockerFilePath": "/Dockerfile",
      "dockerWorkDir": "/packages/ml",
      "buildkit": { "useCache": true, "cacheStorageSize": 32768 }
    }
  },
  "buildConfiguration": {
    "pathIgnoreRules": ["apps/**", "packages/backtest/**", "infra/**"]
  },
  "healthChecks": [
    {
      "protocol": "HTTP",
      "type": "readinessProbe",
      "path": "/health",
      "port": 8001,
      "initialDelaySeconds": 60,
      "periodSeconds": 30,
      "timeoutSeconds": 10,
      "failureThreshold": 5,
      "successThreshold": 1
    }
  ]
}
