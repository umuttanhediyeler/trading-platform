{
  "name": "redis",
  "description": "Redis cache deployment service",
  "billing": {
    "deploymentPlan": "nf-compute-10"
  },
  "deployment": {
    "instances": 1,
    "external": {
      "imagePath": "redis:7-alpine"
    },
    "docker": {
      "configType": "customCommand",
      "customCommand": "redis-server --save 60 1 --loglevel warning"
    },
    "storage": {
      "ephemeralStorage": { "storageSize": 1024 }
    }
  },
  "ports": [
    {
      "name": "p01",
      "internalPort": 6379,
      "public": false,
      "protocol": "TCP"
    }
  ],
  "healthChecks": [
    {
      "protocol": "CMD",
      "type": "readinessProbe",
      "cmd": "redis-cli ping",
      "initialDelaySeconds": 10,
      "periodSeconds": 15,
      "timeoutSeconds": 5,
      "failureThreshold": 3,
      "successThreshold": 1
    }
  ]
}
