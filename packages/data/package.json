{
  "name": "@trading-platform/data",
  "version": "0.1.0",
  "private": true,
  "description": "Shared market-data utilities: bar normalization, indicator math, batching, bounded concurrency and rate limiting for provider-safe bulk scans.",
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc -p tsconfig.json --noEmit",
