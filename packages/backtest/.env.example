# Same Postgres instance as apps/api — the backtest service reads bars and
# writes only its own backtest results.
DATABASE_URL=postgresql://user:pass@localhost:5433/trading

# Port the FastAPI app listens on (apps/api reaches it via BACKTEST_SERVICE_URL).
PORT=8002

# Optional error/performance tracing.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
