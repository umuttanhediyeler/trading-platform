# Shared Postgres with apps/api (Supabase / Neon in production).
# Use ?sslmode=require for managed providers.
DATABASE_URL=postgresql://user:pass@localhost:5432/trading

# Koyeb/Render inject PORT; local default below.
PORT=8001

MODEL_REGISTRY_FALLBACK_PATH=/tmp/ml_model_registry.jsonl
NIGHTLY_SELECTION_FALLBACK_PATH=/tmp/ml_daily_selection.json
MODEL_ARTIFACT_DIR=/tmp/ml_artifacts
MODEL_MIN_PRECISION=0.42
MODEL_MIN_RECALL=0.10
MODEL_MIN_EXPECTANCY=0.0
MODEL_MAX_DRAWDOWN=0.15
MODEL_MIN_TRAINING_SAMPLES=30

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
