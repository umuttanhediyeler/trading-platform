# Same Postgres instance as apps/api — the ML service reads bars/features
# and writes only to ModelRegistry / DailyStrategySelection.
DATABASE_URL=postgresql://user:pass@localhost:5433/trading

# Port the FastAPI app listens on (apps/api reaches it via ML_SERVICE_URL).
PORT=8001

# Optional local fallbacks used when Postgres is unreachable.
MODEL_REGISTRY_FALLBACK_PATH=/tmp/ml_model_registry.jsonl
NIGHTLY_SELECTION_FALLBACK_PATH=/tmp/ml_daily_selection.json
MODEL_ARTIFACT_DIR=/tmp/ml_artifacts
# Bootstrap paper-model gates. Tighten after enough resolved signals accrue.
MODEL_MIN_PRECISION=0.35
MODEL_MIN_RECALL=0.10
MODEL_MIN_EXPECTANCY=0.0
MODEL_MAX_DRAWDOWN=0.15
MODEL_MIN_TRAINING_SAMPLES=30

# Optional error/performance tracing.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
