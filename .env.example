# ==========================================================================
# Trading Platform — environment variable reference (placeholders only).
#
# This root file documents EVERY variable and where it is consumed. Copy the
# relevant sections into each service's own env file (they are git-ignored):
#   - apps/api/.env
#   - apps/web/.env.local
#   - packages/ml/.env
#   - packages/backtest/.env
#
# NEVER commit real secrets. See cursor_detailed_spec.md §2 and §9.
# ==========================================================================

# --- Shared: Postgres (same DB for api, ml, backtest) ---------------------
# consumed by: apps/api/.env, packages/ml/.env, packages/backtest/.env
DATABASE_URL=postgresql://user:pass@localhost:5432/trading

# --- apps/api -------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# Observability and critical operational alerts (optional)
SENTRY_DSN=
# Slack/Discord-compatible incoming webhook for operational alerts.
ALERT_WEBHOOK_URL=
# Optional email alert channel via Resend (https://resend.com), dependency-free HTTP.
# Enabled only when RESEND_API_KEY + ALERT_EMAIL_FROM + ALERT_EMAIL_TO are all set.
# The API key is never logged. consumed by: apps/api
RESEND_API_KEY=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_EMAIL_MIN_SEVERITY=warning

# Backend API token signing. MUST differ from NEXTAUTH_SECRET.
JWT_SECRET=changeme-generate-with-openssl-rand-base64-32

# AES-256-GCM key for encrypting stored broker credentials (32 bytes hex).
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=changeme-openssl-rand-hex-32

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_BASIC=price_xxx
STRIPE_PRICE_ID_PREMIUM=price_xxx

# Market data provider
POLYGON_API_KEY=your-polygon-api-key

# Bulk scan / backfill provider budget (optional; sensible defaults built in).
# Requests per minute allowed for bulk historical-bar fetches (scan fallback
# and nightly backfill). Keep below the vendor quota (Alpaca free tier: 200).
SCAN_PROVIDER_MAX_REQUESTS_PER_MINUTE=180
# Concurrent per-symbol requests when the provider has no batch endpoint.
SCAN_PROVIDER_CONCURRENCY=4
# Symbols per multi-symbol batch request (Alpaca supports ~100 comfortably).
SCAN_PROVIDER_BATCH_SIZE=100

# Internal Python services
ML_SERVICE_URL=http://localhost:8001
BACKTEST_SERVICE_URL=http://localhost:8002

# Alpaca (dev/test account only; per-user keys are stored encrypted in the DB)
ALPACA_API_KEY=your-alpaca-key
ALPACA_SECRET_KEY=your-alpaca-secret
# Paper: https://paper-api.alpaca.markets  |  Live: https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- apps/web (.env.local) ------------------------------------------------
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=changeme-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
