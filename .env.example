# ==========================================================================
# Trading Platform — environment variable reference (placeholders only).
#
# Deployment targets (no docker-compose / nginx):
#   - Vercel          → apps/web
#   - Koyeb / Render  → apps/api, packages/ml, packages/backtest
#   - Supabase / Neon → Postgres (DATABASE_URL)
#   - Upstash         → Redis (REDIS_URL)
#
# Copy into each service's own env file (git-ignored):
#   - apps/api/.env
#   - apps/web/.env.local   (from apps/web/.env.example)
#   - packages/ml/.env
#   - packages/backtest/.env
#
# NEVER commit real secrets.
# ==========================================================================

# --- Shared: Postgres (api + ml) ------------------------------------------
# Supabase/Neon: paste the connection string; append ?sslmode=require if needed.
DATABASE_URL=postgresql://user:pass@localhost:5432/trading

# --- apps/api -------------------------------------------------------------
PORT=3001
REDIS_URL=redis://localhost:6379
WEB_ORIGIN=http://localhost:3000
ML_SERVICE_URL=http://localhost:8001
BACKTEST_SERVICE_URL=http://localhost:8002
JWT_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=
SENTRY_DSN=
ALERT_WEBHOOK_URL=
RESEND_API_KEY=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_EMAIL_MIN_SEVERITY=warning
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_BASIC=
STRIPE_PRICE_ID_PREMIUM=
MARKET_DATA_PROVIDER=alpaca
ALPACA_DATA_FEED=iex
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
POLYGON_API_KEY=
ALLOW_LIVE_BROKER=false
ALLOW_FULL_AUTO_LIVE=false

# --- apps/web (.env.local / Vercel) ---------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- packages/ml ----------------------------------------------------------
# PORT=8001  DATABASE_URL=...

# --- packages/backtest ----------------------------------------------------
# PORT=8002
